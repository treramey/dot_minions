#!/usr/bin/env bash

set -euo pipefail

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly RESET='\033[0m'
readonly BOLD='\033[1m'
readonly SCRIPT_NAME="minion"
readonly VERSION="2.2.0"

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
ROOT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
readonly ROOT_DIR
readonly SHELF_FILE="$ROOT_DIR/shelf.json"
readonly LOCK_FILE="$ROOT_DIR/.skill-lock.json"
readonly SKILLS_DIR="$ROOT_DIR/skills"

# Harnesses the store fans out to. Symlinks are absolute and uniform across all
# three, so depth (Claude/Codex are 2 levels deep, Pi is 3) does not matter.
readonly HARNESS_DIRS=(
    "$HOME/.claude/skills"
    "$HOME/.codex/skills"
    "$HOME/.pi/agent/skills"
)

# Plannotator core skills are managed through the skills CLI like every other
# store skill. The Plannotator binary/hooks are installed separately by
# https://plannotator.ai/install.sh when needed; minion only manages skills.
readonly PLANNOTATOR_CORE_SKILLS=(
    "plannotator-review"
    "plannotator-annotate"
    "plannotator-last"
)
readonly PLANNOTATOR_EXTRA_SKILLS=(
    "plannotator-compound"
    "plannotator-setup-goal"
    "plannotator-visual-explainer"
)


print_header()  { echo -e "\n${BOLD}${BLUE}==>${RESET} ${BOLD}$1${RESET}"; }
print_success() { echo -e "${GREEN}✓${RESET} $1"; }
print_error()   { echo -e "${RED}✗${RESET} $1" >&2; }
print_warning() { echo -e "${YELLOW}⚠${RESET} $1"; }
print_info()    { echo -e "${CYAN}ℹ${RESET} $1"; }

command_exists() { command -v "$1" >/dev/null 2>&1; }

pretty_path() {
    local p="$1"
    if [[ "$p" == "$HOME"/* ]]; then
        echo "~/${p#"$HOME"/}"
    else
        echo "$p"
    fi
}

confirm() {
    local prompt="${1:-Continue?}" default="${2:-n}"
    if [[ "$default" == "y" ]]; then prompt="$prompt [Y/n]: "; else prompt="$prompt [y/N]: "; fi
    read -r -p "$prompt" response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        [nN][oO]|[nN]) return 1 ;;
        "") [[ "$default" == "y" ]] && return 0 || return 1 ;;
        *) return 1 ;;
    esac
}

require_cmd() {
    local cmd="$1"
    command_exists "$cmd" || {
        print_error "Missing required command: $cmd"
        exit 1
    }
}

require_file() {
    local file="$1"
    [[ -f "$file" ]] || {
        print_error "Missing required file: $file"
        exit 1
    }
}

ensure_shelf_file() {
    if [[ ! -f "$SHELF_FILE" ]]; then
        printf '[]\n' > "$SHELF_FILE"
    fi
}

require_clean() {
    require_cmd git
    local untracked
    untracked=$(git -C "$ROOT_DIR" ls-files --others --exclude-standard)

    git -C "$ROOT_DIR" diff --quiet && git -C "$ROOT_DIR" diff --cached --quiet && [[ -z "$untracked" ]] || {
        print_error "Uncommitted changes in git"
        exit 1
    }
}

json_update() {
    local tmp
    tmp=$(mktemp)
    jq "$@" "$SHELF_FILE" > "$tmp"
    mv "$tmp" "$SHELF_FILE"
}

print_prefixed() {
    local prefix="$1" color="$2"
    while IFS= read -r line; do
        [[ -n "$line" ]] && echo -e "  ${color}${prefix} $line${RESET}"
    done
}

# --- store + symlink helpers -------------------------------------------------

# Names of every skill in the store (a dir containing SKILL.md), one per line.
store_skills() {
    [[ -d "$SKILLS_DIR" ]] || return 0
    local path
    shopt -s nullglob
    for path in "$SKILLS_DIR"/*/; do
        [[ -f "${path}SKILL.md" ]] && basename "$path"
    done
    shopt -u nullglob
}

is_shelved() {
    local name="$1"
    ensure_shelf_file
    jq -e --arg n "$name" 'index($n) != null' "$SHELF_FILE" >/dev/null 2>&1
}

array_contains() {
    local needle="$1" item
    shift || true
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

is_plannotator_core_skill() { array_contains "$1" "${PLANNOTATOR_CORE_SKILLS[@]}"; }

should_link_skill_to_harness() {
    local name="$1" harness="$2"
    return 0
}

shelve_plannotator_extras() {
    local skill
    for skill in "${PLANNOTATOR_EXTRA_SKILLS[@]}"; do
        if [[ -d "$SKILLS_DIR/$skill" ]]; then
            json_update --arg n "$skill" '. + [$n] | unique | sort'
        fi
    done
}

# Paths of symlinks in a harness that point into the store, one per line. These
# are the only entries minion owns; everything else (foreign skills, plain
# files) is left untouched.
store_links_in() {
    local harness="$1" target dest
    [[ -d "$harness" ]] || return 0
    shopt -s nullglob
    for target in "$harness"/*; do
        [[ -L "$target" ]] || continue
        dest="$(readlink "$target")"
        [[ "$dest" == "$SKILLS_DIR/"* ]] && printf '%s\n' "$target"
    done
    shopt -u nullglob
}

# How many harnesses currently hold a live symlink for <name>.
skill_coverage() {
    local name="$1" harness target dest count=0
    for harness in "${HARNESS_DIRS[@]}"; do
        target="$harness/$name"
        [[ -L "$target" && -e "$target" ]] || continue
        dest="$(readlink "$target")"
        [[ "$dest" == "$SKILLS_DIR/"* ]] && count=$((count + 1))
    done
    echo "$count"
}

skill_expected_coverage() {
    echo "${#HARNESS_DIRS[@]}"
}

harness_link_count() { store_links_in "$1" | wc -l | tr -d ' '; }

# Point <harness>/<name> at $SKILLS_DIR/<name> in every harness. Replaces a
# stale copy (real dir of the same name) or any existing symlink; never touches
# a foreign skill (a name not present in the store) or a plain file.
link_skill() {
    local name="$1" src="$SKILLS_DIR/$name"
    local harness target
    for harness in "${HARNESS_DIRS[@]}"; do
        should_link_skill_to_harness "$name" "$harness" || continue
        mkdir -p "$harness"
        target="$harness/$name"
        if [[ ! -L "$target" && -e "$target" ]]; then
            if [[ -d "$target" ]]; then
                rm -rf "$target"   # stale copy we own by name -> replace with link
            else
                print_warning "Skipping non-dir file: $(pretty_path "$target")"
                continue
            fi
        fi
        ln -sfn "$src" "$target"
    done
}

# Remove <harness>/<name> in every harness, but only if it is a symlink. Never
# deletes a real dir we do not own.
unlink_skill() {
    local name="$1" harness target
    for harness in "${HARNESS_DIRS[@]}"; do
        target="$harness/$name"
        [[ -L "$target" ]] && rm -f "$target"
    done
    return 0
}

# Remove store-pointing symlinks that are now dangling or shelved. Echoes the
# number pruned. Leaves live, active links and all foreign entries in place.
prune_dead_links() {
    local harness link name pruned=0
    for harness in "${HARNESS_DIRS[@]}"; do
        while IFS= read -r link; do
            [[ -n "$link" ]] || continue
            name="$(basename "$link")"
            if [[ ! -e "$link" ]] || is_shelved "$name" || ! should_link_skill_to_harness "$name" "$harness"; then
                rm -f "$link"
                pruned=$((pruned + 1))
            fi
        done < <(store_links_in "$harness")
    done
    echo "$pruned"
}

# --- listings ----------------------------------------------------------------

list_active_skills() {
    local names name cov expected color
    names=$(store_skills | sort)

    # Active = in the store and not shelved.
    local printed=0
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if is_shelved "$name"; then continue; fi
        cov=$(skill_coverage "$name")
        expected=$(skill_expected_coverage "$name")
        if [[ "$cov" -eq "$expected" ]]; then
            color="$GREEN"
        elif [[ "$cov" -eq 0 ]]; then
            color="$YELLOW"
        else
            color="$CYAN"
        fi
        echo -e "  ${color}▸ ${name} (${cov}/${expected})${RESET}"
        printed=$((printed + 1))
    done <<< "$names"

    [[ "$printed" -eq 0 ]] && echo -e "  ${YELLOW}(none)${RESET}"
    return 0
}

list_shelved_skills() {
    ensure_shelf_file

    local entries
    entries=$(jq -r '.[]' "$SHELF_FILE")

    if [[ -z "$entries" ]]; then
        echo -e "  ${YELLOW}(none)${RESET}"
    else
        printf '%s\n' "$entries" | print_prefixed "▹" "$BLUE"
    fi
}

install_plannotator_core() {
    [[ $# -eq 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} plannotator-core"
        return 1
    }
    require_cmd npx
    require_cmd jq

    print_header "Refreshing Plannotator core skills"
    if (cd "$ROOT_DIR" && npx skills add backnotprop/plannotator/apps/skills/core --global --yes \
        --skill plannotator-review \
        --skill plannotator-annotate \
        --skill plannotator-last); then
        print_success "Plannotator core skills refreshed"
    else
        print_warning "skills CLI reported errors while refreshing Plannotator core (continuing)"
    fi

    # Core-only means the extras stay in the store but are not active unless the
    # user explicitly reactivates them.
    shelve_plannotator_extras
}

# --- commands ----------------------------------------------------------------

cmd_census() {
    require_cmd jq
    ensure_shelf_file

    print_header "Active minions"
    list_active_skills
    print_header "Shelved minions"
    list_shelved_skills
}

cmd_activate() {
    [[ $# -gt 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} activate <name>..."
        return 1
    }
    require_cmd jq
    ensure_shelf_file

    local name
    for name in "$@"; do
        if [[ ! -f "$SKILLS_DIR/$name/SKILL.md" ]]; then
            print_error "Not in store: $name"
            return 1
        fi
        json_update --arg n "$name" '. - [$n]'
        link_skill "$name"
        print_success "Activated: ${BOLD}$name${RESET}"
    done
}

cmd_kill() {
    [[ $# -gt 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} kill <name>..."
        return 1
    }
    require_cmd jq
    ensure_shelf_file

    local name
    for name in "$@"; do
        unlink_skill "$name"
        json_update --arg n "$name" '. + [$n] | unique | sort'
        print_warning "Shelved: ${BOLD}$name${RESET}"
    done
}

cmd_install_all() {
    [[ $# -eq 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} install"
        return 1
    }
    require_cmd jq
    require_cmd npx
    require_cmd git
    ensure_shelf_file
    # require_clean

    # 1. Refresh the global store from the global lock + sources. Do not use
    #    experimental_install here: it restores project skills into
    #    "$ROOT_DIR/.agents/skills", which is not minion's store.
    print_header "Refreshing store"
    if (cd "$ROOT_DIR" && npx skills update --global --yes); then
        print_success "Updated store skills to latest"
    else
        print_warning "update reported errors (continuing)"
    fi

    # 2. Plannotator's extra skills live under a repo path that the skills CLI
    #    update command currently mis-detects. Refresh the core skills from the
    #    explicit core path and keep extras shelved.
    install_plannotator_core

    # 3. Fan the store out: every active (non-shelved) store skill -> harnesses.
    print_header "Linking active skills into harnesses"
    local linked=0 skipped=0 name
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if is_shelved "$name"; then
            skipped=$((skipped + 1))
            continue
        fi
        link_skill "$name"
        linked=$((linked + 1))
    done < <(store_skills)

    # 4. Drop links that are now dangling or shelved.
    local pruned
    pruned=$(prune_dead_links)

    # 5. Summary.
    print_header "Sync summary"
    local total
    total=$(store_skills | wc -l | tr -d ' ')
    print_info "Store: ${total} skills (${linked} active, ${skipped} shelved)"
    local harness
    for harness in "${HARNESS_DIRS[@]}"; do
        print_info "$(pretty_path "$harness"): $(harness_link_count "$harness") linked"
    done
    [[ "$pruned" -gt 0 ]] && print_warning "Pruned ${pruned} dead/shelved link(s)"
    print_success "Install complete"
}

cmd_add() {
    [[ $# -gt 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} add <repo> [skill...]"
        return 1
    }
    require_cmd jq
    require_cmd npx
    ensure_shelf_file

    local repo="$1"; shift
    local skills_arg='*'
    if [[ $# -gt 0 ]]; then
        skills_arg="$(IFS=,; echo "$*")"
    fi

    print_header "Adding ${repo} to the store"
    if ! (cd "$ROOT_DIR" && npx skills add "$repo" --global --skill "$skills_arg" --yes); then
        print_warning "npx skills add reported errors (continuing to link what landed)"
    fi

    print_header "Linking active skills into harnesses"
    local linked=0 name
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if is_shelved "$name"; then continue; fi
        link_skill "$name"
        linked=$((linked + 1))
    done < <(store_skills)
    prune_dead_links >/dev/null

    print_success "Added ${repo}; ${linked} active skill(s) linked"
}

cmd_reset_skills() {
    [[ $# -eq 0 ]] || {
        print_error "Usage: ${SCRIPT_NAME} reset"
        return 1
    }
    require_cmd jq
    ensure_shelf_file

    if ! confirm "Unlink every store skill from all harnesses and clear the shelf?" "n"; then
        print_info "Cancelled."
        return 0
    fi

    local harness link
    for harness in "${HARNESS_DIRS[@]}"; do
        while IFS= read -r link; do
            [[ -n "$link" ]] && rm -f "$link"
        done < <(store_links_in "$harness")
    done

    printf '[]\n' > "$SHELF_FILE"
    print_success "Unlinked all store skills and reset the shelf. Store and lock left intact."
}

cmd_mdformat_check() {
    require_cmd uvx
    if [[ $# -eq 0 ]]; then
        set -- .
    fi
    (cd "$ROOT_DIR" && uvx mdformat --check "$@")
}

cmd_mdformat_write() {
    require_cmd uvx
    if [[ $# -eq 0 ]]; then
        set -- .
    fi
    (cd "$ROOT_DIR" && uvx mdformat "$@")
}

cmd_help() {
    echo -e "${BOLD}${SCRIPT_NAME}${RESET} - Skill store + multi-harness symlink manager (v${VERSION})"
    echo ""
    echo -e "${BOLD}USAGE:${RESET}"
    echo "    ${SCRIPT_NAME} [OPTIONS] COMMAND [ARGS]"
    echo ""
    echo -e "${BOLD}COMMANDS:${RESET}"
    echo "    census                      Show active (with harness coverage) and shelved minions"
    echo "    install                     Refresh the store, refresh Plannotator core, then symlink skills"
    echo "    plannotator-core            Refresh Plannotator core skills via npx skills add"
    echo "    add <repo> [skill...]       Add skills from a repo to the store, then symlink them"
    echo "    activate <name>...          Unshelve store skills and symlink them into every harness"
    echo "    kill <name>...              Shelve skills: drop their symlinks, keep the store copy"
    echo "    reset                       Unlink every store skill from all harnesses and clear the shelf"
    echo "    check [path]                Check Markdown formatting"
    echo "    format [path]               Format Markdown files"
    echo "    help                        Show this help"
    echo ""
    echo -e "${BOLD}OPTIONS:${RESET}"
    echo "    --version                   Show version"
    echo "    -h, --help                  Show help"
    echo ""
    echo -e "${BOLD}HARNESSES:${RESET}"
    local harness
    for harness in "${HARNESS_DIRS[@]}"; do
        echo "    $(pretty_path "$harness")"
    done
    echo ""
    echo -e "${BOLD}CONFIGURATION:${RESET}"
    echo "    Root:   ${ROOT_DIR}"
    echo "    Shelf:  ${SHELF_FILE}"
    echo "    Lock:   ${LOCK_FILE}"
    echo "    Store:  ${SKILLS_DIR}"
    echo ""
}

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --version) echo "${SCRIPT_NAME} v${VERSION}"; exit 0 ;;
            -h|--help) cmd_help; exit 0 ;;
            *) break ;;
        esac
    done

    local cmd="${1:-census}"
    shift || true

    case "$cmd" in
        census)     cmd_census "$@" ;;
        activate)   cmd_activate "$@" ;;
        kill)       cmd_kill "$@" ;;
        install)    cmd_install_all "$@" ;;
        plannotator-core)
                    install_plannotator_core "$@" ;;
        add)        cmd_add "$@" ;;
        reset)      cmd_reset_skills "$@" ;;
        check)      cmd_mdformat_check "$@" ;;
        format)     cmd_mdformat_write "$@" ;;
        help)       cmd_help ;;
        *)
            print_error "Unknown command: $cmd"
            echo "Run '${SCRIPT_NAME} help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
